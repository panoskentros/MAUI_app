<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_app.View.MainPage"
             BackgroundColor="#F5F5F7"
             Shell.NavBarIsVisible="False"> <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#42A5F5" Offset="0.1" />
                    <GradientStop Color="#0D47A1" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <Border Margin="30" 
                    Padding="40" 
                    BackgroundColor="White"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="450"
                    WidthRequest="450">
                
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="15">
                    <Image Source="medical_logo.png"
                           HeightRequest="80"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>
                    
                    <Label x:Name="WelcomeLabel"
                           Text="Patient Portal"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#1C1C1E"
                           HorizontalOptions="Center" />

                    <Label x:Name="StatusLabel"
                           Text="Log in to manage your appointments"
                           FontSize="14"
                           TextColor="#8E8E93"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>

                    <Entry x:Name="UsernameEntry"
                           Placeholder="Username"
                           Text="{Binding UserName}"
                           HeightRequest="50"
                           BackgroundColor="#F2F2F7"
                           TextColor="Black" 
                           ReturnType="Next" />
                    
                    <Entry x:Name="EmailEntry"
                           Placeholder="Email Address"
                           Text="{Binding Email}"
                           Keyboard="Email"
                           HeightRequest="50"
                           BackgroundColor="#F2F2F7"
                           TextColor="Black" 
                           ReturnType="Next" />

                    <Entry x:Name="PasswordEntry"
                           Placeholder="Password"
                           Text="{Binding HashedPassword}"
                           IsPassword="True"
                           HeightRequest="50"
                           BackgroundColor="#F2F2F7"
                           TextColor="Black" 
                           ReturnType="Done" 
                           Completed="OnPasswordEntryCompleted" />

                    <ActivityIndicator x:Name="LoadingIndicator" 
                                       IsRunning="False" 
                                       IsVisible="False"
                                       Color="#0D47A1"
                                       HeightRequest="40" />
                    
                    <Button x:Name="LoginBtn"
                            Text="Sign In" 
                            Clicked="OnLoginClicked"
                            BackgroundColor="#0D47A1"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="12"
                            FontAttributes="Bold" />
                    
                    <Button x:Name="GoToRegisterBtn"
                            Text="New Patient? Register Here" 
                            Clicked="OnGoToRegisterClicked"
                            BackgroundColor="Transparent"
                            TextColor="#0D47A1"
                            HeightRequest="50"
                            CornerRadius="12"
                            FontAttributes="Bold" />
                    
                    <Button x:Name="LogoutBtn"
                            Text="Sign Out" 
                            Clicked="OnLogoutClickedAsync"
                            BackgroundColor="Transparent"
                            TextColor="#FF3B30"
                            BorderColor="#FF3B30"
                            BorderWidth="1"
                            HeightRequest="50"
                            CornerRadius="12"
                            IsVisible="False" />

                    <Button x:Name="ExitBtn"
                            Text="EXIT"
                            Clicked="OnExitClicked"
                            BackgroundColor="#FF3B30" 
                            TextColor="White"          
                            FontSize="11"
                            HeightRequest="44"
                            CornerRadius="12"
                            Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>