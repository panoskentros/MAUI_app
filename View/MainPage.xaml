<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_app.View.MainPage"
             BackgroundColor="#F5F5F7"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled">
    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#42A5F5" Offset="0.1" />
                    <GradientStop Color="#0D47A1" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <Border Margin="30" 
                    BackgroundColor="White"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="900"
                    WidthRequest="900"
                    HeightRequest="600">
                
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1" />
                </Border.Shadow>
                
                <Grid ColumnDefinitions="*, *">
                    
                    <Grid Grid.Column="0">
                        <Image Source="hospital_hero.png" 
                               Aspect="AspectFill" />
                        
                        <BoxView BackgroundColor="#0D47A1" Opacity="0.6" />
                        
                        <VerticalStackLayout VerticalOptions="Center" Margin="40">
                            <Label Text="Your Health," FontSize="36" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Our Priority" FontSize="36" FontAttributes="Bold" TextColor="White" Margin="0,0,0,10"/>
                            <Label Text="Manage your appointments, view test results, and stay connected with your healthcare providers all in one secure place." 
                                   FontSize="16" TextColor="#E3F2FD" LineHeight="1.5" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Grid.Column="1" Spacing="15" Padding="40" VerticalOptions="Center">
                        
                        <Image Source="medical_logo.png" HeightRequest="60" HorizontalOptions="Center" Margin="0,0,0,10"/>
                        
                        <Label x:Name="WelcomeLabel" Text="Hospital Portal" FontSize="28" FontAttributes="Bold" TextColor="#1C1C1E" HorizontalOptions="Center" />
                        <Label x:Name="StatusLabel" Text="Please log in to continue" FontSize="14" TextColor="#8E8E93" HorizontalOptions="Center" Margin="0,0,0,10"/>

                        <Border BackgroundColor="#F2F2F7" 
                                StrokeThickness="0" 
                                HeightRequest="50"
                                Margin="0,0,0,15">
    
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" /> 
                            </Border.StrokeShape>
    
                            <Grid ColumnDefinitions="Auto, *">
                                <Image Grid.Column="0" 
                                       Source="user_icon.png" 
                                       WidthRequest="22" 
                                       HeightRequest="22" 
                                       Margin="15,0,10,0" 
                                       VerticalOptions="Center" />
                
                                <Entry x:Name="UsernameOrEmailEntry" 
                                       Grid.Column="1" 
                                       Margin="0,0,4,0"
                                       Placeholder="Username or Email" 
                                       BackgroundColor="Transparent" 
                                       TextColor="Black" 
                                       ReturnType="Next" 
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border BackgroundColor="#F2F2F7" 
                                StrokeThickness="0" 
                                HeightRequest="50"
                                Margin="0,0,0,15">
    
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
    
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Image Grid.Column="0" Source="key_icon.png" WidthRequest="22" HeightRequest="22" Margin="15,0,10,0" VerticalOptions="Center" />
                                
                                <Entry x:Name="PasswordEntry" 
                                       Grid.Column="1" 
                                       Placeholder="Password" 
                                       IsPassword="True"
                                       BackgroundColor="Transparent" 
                                       TextColor="Black" 
                                       ReturnType="Done" 
                                       VerticalOptions="Center"
                                       Completed="OnLoginClicked"/>
                                
                                <Image x:Name="TogglePasswordBtn" 
                                       Grid.Column="2" 
                                       Source="eye_slash_icon.png" 
                                       WidthRequest="22" 
                                       HeightRequest="22" 
                                       Aspect="AspectFit"
                                       Margin="0,0,15,0" 
                                       VerticalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTogglePasswordClicked" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                        </Border>
                        
                        <Grid Margin="0,10,0,0" HeightRequest="50">
                            <Button x:Name="LoginBtn" 
                                    Text="Sign In" 
                                    Clicked="OnLoginClicked" 
                                    BackgroundColor="#0D47A1" 
                                    TextColor="White" 
                                    CornerRadius="12" 
                                    FontAttributes="Bold" />
                            <ActivityIndicator x:Name="LoadingIndicator" 
                                               IsRunning="False" 
                                               IsVisible="False" 
                                               Color="White" 
                                               HeightRequest="25" 
                                               WidthRequest="25" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center" 
                                               InputTransparent="True" />
                        </Grid>
                        <Button x:Name="GoToRegisterBtn" Text="New Patient? Register Here" Clicked="OnGoToRegisterClicked" BackgroundColor="Transparent" TextColor="#0D47A1" HeightRequest="50" CornerRadius="12" FontAttributes="Bold" />
                        
                        <Button x:Name="ExitBtn" Text="EXIT" Clicked="OnExitClicked" BackgroundColor="#FF3B30" TextColor="White" FontSize="11" HeightRequest="40" CornerRadius="12" HorizontalOptions="Center" WidthRequest="100" Margin="0,5,0,0" />
                        
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>