<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.BookAppointmentPage"
             BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=Black}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <view:HeaderBanner Grid.Row="0" />

        <ScrollView Grid.Row="1" Margin="20,20,20,0">
            <VerticalStackLayout Spacing="20" Padding="0,0,0,40">

                <VerticalStackLayout x:Name="PatientPickerContainer" Spacing="5">
                    <Label Text="Select Patient" 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" 
                            Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                            StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Picker x:Name="PatientPicker"
                                ItemDisplayBinding="{Binding UserName}"
                                Title="Choose a patient..."
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                TitleColor="{AppThemeBinding Light=Gray, Dark={StaticResource Gray400}}"
                                Margin="10,0" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Select Doctor" 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" 
                            Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                            StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle  CornerRadius="8" /></Border.StrokeShape>
                        <Picker x:Name="DoctorPicker"
                                ItemDisplayBinding="{Binding UserName}"
                                Title="Choose a doctor..."
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                TitleColor="{AppThemeBinding Light=Gray, Dark={StaticResource Gray400}}"
                                Margin="10,0" />
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Date" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                        <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" 
                                Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                                StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <DatePicker x:Name="ApptDatePicker" 
                                        Margin="10,0" 
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Time" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                        <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" 
                                Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                                StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <TimePicker x:Name="ApptTimePicker" 
                                        Margin="10,0" 
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Reason for Visit (Optional)" 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" 
                            Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                            StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Editor x:Name="NotesEditor" 
                                Placeholder="E.g., Checkup..." 
                                PlaceholderColor="{AppThemeBinding Light=Gray, Dark={StaticResource Gray400}}"
                                HeightRequest="100" 
                                Margin="10,5" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="Confirm Appointment"
                        Clicked="OnSaveClicked"
                        BackgroundColor="#0D47A1"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        Margin="0,20,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>