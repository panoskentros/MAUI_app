<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.MessagesPage"
             BackgroundColor="#F4F6F8"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        <view:HeaderBanner x:Name="PageBanner" Grid.Row="0" />

        <Grid Grid.Row="1" RowDefinitions="Auto, *" Padding="20,10,20,30" RowSpacing="20">
            
            <Label Grid.Row="0" Text="Inbox" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" />

            <CollectionView x:Name="MessagesList" Grid.Row="1">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Stroke="{Binding BorderColor}" StrokeThickness="2" Padding="20" Margin="5,5,5,15">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.05" /></Border.Shadow>
                            
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="{Binding Sender}" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50" />
                                    <Label Grid.Column="1" Text="{Binding Time}" TextColor="#3498DB" FontSize="12" FontAttributes="Bold" />
                                </Grid>
                                <Label Text="{Binding Subject}" FontAttributes="Bold" TextColor="#2C3E50" FontSize="14" />
                                <Label Text="{Binding PreviewText}" TextColor="#7F8C8D" FontSize="14" LineBreakMode="TailTruncation" MaxLines="1"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>