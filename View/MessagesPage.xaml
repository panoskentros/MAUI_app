<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.MessagesPage"
             BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=Black}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        <view:HeaderBanner x:Name="PageBanner" Grid.Row="0" />

        <Grid Grid.Row="1" RowDefinitions="Auto, *" Padding="20,10,20,30" RowSpacing="20">
            
            <Label Grid.Row="0" 
                   Text="Inbox" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" />

            <CollectionView x:Name="MessagesList" Grid.Row="1">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" 
                                Stroke="{Binding BorderColor}" 
                                StrokeThickness="2" 
                                Padding="20" 
                                Margin="5,5,5,15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                            </Border.Shadow>
                            
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" 
                                           Text="{Binding Sender}" 
                                           FontAttributes="Bold" 
                                           FontSize="16" 
                                           TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" />
                                    
                                    <Label Grid.Column="1" 
                                           Text="{Binding Time}" 
                                           TextColor="{AppThemeBinding Light=#3498DB, Dark=#5DADE2}" 
                                           FontSize="12" 
                                           FontAttributes="Bold" />
                                </Grid>
                                
                                <Label Text="{Binding Subject}" 
                                       FontAttributes="Bold" 
                                       TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" 
                                       FontSize="14" />
                                
                                <Label Text="{Binding PreviewText}" 
                                       TextColor="{AppThemeBinding Light=#7F8C8D, Dark={StaticResource Gray400}}" 
                                       FontSize="14" 
                                       LineBreakMode="TailTruncation" 
                                       MaxLines="1"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>