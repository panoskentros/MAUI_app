<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_app.View.RegisterPage"
             BackgroundColor="#F5F5F7">

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6200EE" Offset="0.1" />
                    <GradientStop Color="#3700B3" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <Border Margin="30" 
                    Padding="40" 
                    BackgroundColor="White"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1" />
                </Border.Shadow>
                 
                <VerticalStackLayout Spacing="15">
                    <Image Source="dotnet_bot.png"
                           HeightRequest="80"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>
                    
                    <Label x:Name="WelcomeLabel"
                           Text="Create Account"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#1C1C1E"
                           HorizontalOptions="Center" />

                    <Label x:Name="StatusLabel"
                           Text="Please fill in the details below"
                           FontSize="14"
                           TextColor="#8E8E93"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>

                    <Entry Placeholder="Username"
                           Text="{Binding UserName}" 
                           HeightRequest="50"
                           BackgroundColor="#F2F2F7"
                           TextColor="Black" />

                    <Entry Placeholder="Email Address"
                           Text="{Binding Email}"
                           Keyboard="Email"
                           HeightRequest="50"
                           BackgroundColor="#F2F2F7"
                           TextColor="Black" />

                    <Entry Placeholder="Password"
                           Text="{Binding HashedPassword}"
                           IsPassword="True"
                           HeightRequest="50"
                           BackgroundColor="#F2F2F7"
                           TextColor="Black" />

                    <Entry x:Name="ConfirmPassword"
                            Placeholder="Confirm Password"
                           IsPassword="True"
                           HeightRequest="50"
                           BackgroundColor="#F2F2F7"
                           TextColor="Black" />
                    <ActivityIndicator x:Name="LoadingIndicator" 
                                       IsRunning="False" 
                                       IsVisible="False"
                                       Color="#6200EE"
                                       HeightRequest="40" />
                    
                    <Button x:Name="RegisterBtn"
                            Text="Sign Up" 
                            Clicked="OnRegisterClicked"
                            BackgroundColor="#6200EE"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="12"
                            FontAttributes="Bold" />
                    
                    <Button x:Name="BackToLoginBtn"
                            Text="Back to Login" 
                            Clicked="OnBackToLoginClicked"
                            BackgroundColor="Transparent"
                            TextColor="#6200EE"
                            HeightRequest="50"
                            CornerRadius="12"
                            FontAttributes="Bold" />
                            
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>