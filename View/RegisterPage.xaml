<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_app.View.RegisterPage"
             BackgroundColor="#F5F5F7"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled">
    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#42A5F5" Offset="0.1" />
                    <GradientStop Color="#0D47A1" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <Border Margin="30" 
                    BackgroundColor="White"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="900"
                    WidthRequest="900"
                    HeightRequest="600">
                
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1" />
                </Border.Shadow>
                
                <Grid ColumnDefinitions="*, *">
                    
                    <VerticalStackLayout Grid.Column="0" Spacing="15" Padding="40" VerticalOptions="Center">
                        
                        <Label x:Name="WelcomeLabel" Text="Join Us Today" FontSize="28" FontAttributes="Bold" TextColor="#1C1C1E" HorizontalOptions="Center" />
                        <Label x:Name="StatusLabel" Text="Create an account to book appointments and access your medical history" FontSize="14" TextColor="#8E8E93" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,15"/>

                        <Entry x:Name="UsernameEntry" 
                               Text="{Binding UserName}" 
                               Placeholder="Full Name / Username" 
                               HeightRequest="50" 
                               BackgroundColor="#F2F2F7" 
                               TextColor="Black" 
                               ReturnType="Next" />
                        <Label x:Name="UsernameError" TextColor="#D32F2F" FontSize="12" IsVisible="False" Margin="5,-10,0,0" />

                        <Entry x:Name="EmailEntry" 
                               Text="{Binding Email}" 
                               Placeholder="Email Address" 
                               Keyboard="Email" 
                               HeightRequest="50" 
                               BackgroundColor="#F2F2F7" 
                               TextColor="Black" 
                               ReturnType="Next" />
                        <Label x:Name="EmailError" TextColor="#D32F2F" FontSize="12" IsVisible="False" Margin="5,-10,0,0" />

                        <Border BackgroundColor="#F2F2F7" StrokeThickness="0" HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry x:Name="PasswordEntry" Grid.Column="0" Text="{Binding HashedPassword}" Placeholder="Password" IsPassword="True" BackgroundColor="Transparent" TextColor="Black" ReturnType="Next" />
                                
                                <Image Grid.Column="1" Source="eye_slash_icon.png" WidthRequest="22" HeightRequest="22" Aspect="AspectFit" Margin="0,0,15,0" VerticalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleRegPasswordClicked" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                        </Border>
                        <Label x:Name="PasswordError" TextColor="#D32F2F" FontSize="12" IsVisible="False" Margin="5,-10,0,0" />


                        <Border BackgroundColor="#F2F2F7" StrokeThickness="0" HeightRequest="50">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry x:Name="ConfirmPassword" Grid.Column="0" Placeholder="Confirm Password" IsPassword="True" BackgroundColor="Transparent" TextColor="Black" ReturnType="Done" Completed="OnConfirmPasswordCompleted" />
                                
                                <Image Grid.Column="1" Source="eye_slash_icon.png" WidthRequest="22" HeightRequest="22" Aspect="AspectFit" Margin="0,0,15,0" VerticalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleConfirmPasswordClicked" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                        </Border>
                        <Label x:Name="ConfirmPasswordError" TextColor="#D32F2F" FontSize="12" IsVisible="False" Margin="5,-10,0,0" />
                        
                        <Grid Margin="0,10,0,0" HeightRequest="50">
                            
                            <Button x:Name="RegisterBtn" 
                                    Text="Complete Registration" 
                                    Clicked="OnRegisterClicked" 
                                    BackgroundColor="#0D47A1" 
                                    TextColor="White" 
                                    CornerRadius="12" 
                                    FontAttributes="Bold" />

                            <ActivityIndicator x:Name="LoadingIndicator" 
                                               IsRunning="False" 
                                               IsVisible="False" 
                                               Color="White" 
                                               HeightRequest="25" 
                                               WidthRequest="25" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center" 
                                               InputTransparent="True" />
                        </Grid>
                        
                        <Button x:Name="BackToLoginBtn" Text="Back to Login" Clicked="OnBackToLoginClicked" BackgroundColor="Transparent" TextColor="#0D47A1" HeightRequest="50" CornerRadius="12" FontAttributes="Bold" />
                        
                    </VerticalStackLayout>

                    <Grid Grid.Column="1">
                        <Image Source="hospital_hero.png" Aspect="AspectFill" />
                        
                        <BoxView BackgroundColor="#42A5F5" Opacity="0.7" />
                        
                        <VerticalStackLayout VerticalOptions="Center" Margin="40">
                            <Image Source="medical_logo.png" HeightRequest="80" HorizontalOptions="Start" Margin="0,0,0,20"/>
                            <Label Text="Secure" FontSize="32" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Private" FontSize="32" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Accessible" FontSize="32" FontAttributes="Bold" TextColor="White" Margin="0,0,0,15"/>
                            <Label Text="Your medical data is encrypted and stored safely, accessible only to you and your authorized healthcare professionals." 
                                   FontSize="15" TextColor="#E3F2FD" LineHeight="1.5" />
                        </VerticalStackLayout>
                    </Grid>

                </Grid>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>