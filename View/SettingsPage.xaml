<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.SettingsPage"
             BackgroundColor="{AppThemeBinding Light=#F4F6F8, Dark=Black}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <view:HeaderBanner x:Name="PageBanner" Grid.Row="0" />

        <ScrollView Grid.Row="1" Margin="20,10,20,0">
            <VerticalStackLayout Spacing="20" Padding="0,0,0,30">
                
                <Label Text="Edit Profile" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=#2C3E50, Dark=White}" />

                <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource OffBlack}}" 
                        Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                        StrokeThickness="1" 
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                    </Border.Shadow>
                    
                    <VerticalStackLayout Spacing="15">
                        
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Username" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=Black}" 
                                    Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                                    StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Entry x:Name="UsernameEntry" 
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Email" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=Black}" 
                                    Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                                    StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Entry x:Name="EmailEntry" 
                                       Keyboard="Email"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="New Password (Optional)" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=Black}" 
                                    Stroke="{AppThemeBinding Light=#E0E6ED, Dark={StaticResource Gray600}}" 
                                    StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Entry x:Name="PasswordEntry" 
                                       IsPassword="True"
                                       Placeholder="Leave blank to keep current"
                                       PlaceholderColor="{AppThemeBinding Light=Gray, Dark={StaticResource Gray400}}"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Save Changes" 
                                Clicked="OnSaveClicked"
                                BackgroundColor="#0D47A1" 
                                TextColor="White" 
                                FontSize="16"
                                FontAttributes="Bold" 
                                CornerRadius="8" 
                                HeightRequest="50" 
                                Margin="0,10,0,0" />
                                
                    </VerticalStackLayout>
                </Border>

                <Button Text="Sign Out" 
                        Clicked="OnSignOutClicked"
                        BackgroundColor="{AppThemeBinding Light=#FDEDEC, Dark=#441111}" 
                        TextColor="{AppThemeBinding Light=#E74C3C, Dark=#FF6B6B}" 
                        FontSize="16"
                        FontAttributes="Bold" 
                        CornerRadius="12" 
                        HeightRequest="55" 
                        Margin="0,15,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>