<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.SettingsPage"
             BackgroundColor="#F4F6F8"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <view:HeaderBanner x:Name="PageBanner" Grid.Row="0" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,10,20,30" Spacing="20">
                
                <Label Text="Account Settings" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" />

                <Border BackgroundColor="White" Stroke="#E0E6ED" StrokeThickness="1" Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.05" />
                    </Border.Shadow>
                    
                    <VerticalStackLayout>
                        
                        <Grid Padding="20" ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Personal Information" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text=">" FontSize="20" TextColor="#BDC3C7" VerticalOptions="Center" FontAttributes="Bold"/>
                        </Grid>
                        
                        <BoxView HeightRequest="1" Color="#F0F3F4" Margin="20,0" />
                        
                        <Grid Padding="20" ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                <Label Text="Notifications" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" />
                                <Label Text="Receive alerts for appointments" FontSize="13" TextColor="#7F8C8D" />
                            </VerticalStackLayout>
                        </Grid>
                        
                        <BoxView HeightRequest="1" Color="#F0F3F4" Margin="20,0" />

                        <Grid Padding="20" ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Security &amp; Password" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text=">" FontSize="20" TextColor="#BDC3C7" VerticalOptions="Center" FontAttributes="Bold"/>
                        </Grid>
                        
                    </VerticalStackLayout>
                </Border>

                <Button Text="Sign Out" 
                        BackgroundColor="#FDEDEC" 
                        TextColor="#E74C3C" 
                        FontSize="16"
                        FontAttributes="Bold" 
                        CornerRadius="12" 
                        HeightRequest="55" 
                        Margin="0,15,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>