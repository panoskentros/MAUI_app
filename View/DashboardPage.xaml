<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.DashboardPage"
             BackgroundColor="#F5F5F7"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <view:HeaderBanner x:Name="PageBanner" Grid.Row="0" />

        <ScrollView Grid.Row="1" Margin="20,10,20,0">
            <VerticalStackLayout Spacing="20" Padding="0,0,0,30">
                
                <VerticalStackLayout x:Name="PatientView" Spacing="20" IsVisible="False">

                    <Border BackgroundColor="#0D47A1" StrokeThickness="0" Padding="20">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="#0D47A1" Offset="0,8" Radius="15" Opacity="0.3" /></Border.Shadow>
                        
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                <Image Source="calendar_icon.png" WidthRequest="20" HeightRequest="20">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="#BBDEFB" />
                                    </Image.Behaviors>
                                </Image>
                                <Label Text="UPCOMING APPOINTMENT" FontSize="12" FontAttributes="Bold" TextColor="#BBDEFB" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <Label x:Name="PatientNextApptDateLabel" FontSize="22" FontAttributes="Bold" TextColor="White" />
                            <Label x:Name="PatientNextApptDetailsLabel" FontSize="14" TextColor="#E3F2FD" />
                            
                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Button Text="Reschedule" BackgroundColor="White" TextColor="#0D47A1" CornerRadius="8" HeightRequest="40" FontAttributes="Bold" WidthRequest="120"/>
                                
                                <Button x:Name="PatientMoreApptsButton"
                                        Clicked="OnViewAllAppointmentsClicked"
                                        BackgroundColor="Transparent" 
                                        TextColor="#BBDEFB" 
                                        BorderColor="#BBDEFB" 
                                        BorderWidth="1" 
                                        CornerRadius="8" 
                                        HeightRequest="40" 
                                        FontAttributes="Bold" 
                                        Padding="15,0"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" Margin="0,10,0,0"/>
                    
                    <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="15" RowSpacing="15">
                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="White" StrokeThickness="0" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" /></Border.Shadow>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnBookAppointmentTapped"/></Border.GestureRecognizers>
                            
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                                <Image Source="calendar_icon.png" WidthRequest="30" HeightRequest="30" />
                                <Label Text="Book New" FontSize="14" FontAttributes="Bold" TextColor="#1C1C1E" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="White" StrokeThickness="0" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" /></Border.Shadow>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnMedicalRecordsTapped"/></Border.GestureRecognizers>
                            
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                                <Image Source="pill_icon.png" WidthRequest="30" HeightRequest="30" />
                                <Label Text="My Records" FontSize="14" FontAttributes="Bold" TextColor="#1C1C1E" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
                
                <VerticalStackLayout x:Name="SecretaryView" Spacing="20" IsVisible="False">
                    <Border BackgroundColor="#F2F2F7" StrokeThickness="0" HeightRequest="50">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, *">
                            <Image Grid.Column="0" Source="user_icon.png" WidthRequest="20" HeightRequest="20" Margin="15,0,10,0" Opacity="0.5" />
                            <Entry Grid.Column="1" Placeholder="Search patients by name or phone..." BackgroundColor="Transparent" TextColor="Black" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <Border Grid.Column="0" BackgroundColor="#E3F2FD" StrokeThickness="0" Padding="15">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <VerticalStackLayout>
                                <Label x:Name="SecretaryApptsTodayLabel" FontSize="24" FontAttributes="Bold" TextColor="#0D47A1" />
                                <Label Text="Appointments Today" FontSize="12" TextColor="#0D47A1" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1" BackgroundColor="#FFF3E0" StrokeThickness="0" Padding="15">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <VerticalStackLayout>
                                <Label Text="0" FontSize="24" FontAttributes="Bold" TextColor="#E65100" />
                                <Label Text="Awaiting Check-in" FontSize="12" TextColor="#E65100" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" Margin="0,10,0,0"/>
                    
                    <Button Text="Book Walk-in / Call-in" 
                            Clicked="OnBookAppointmentTapped"
                            BackgroundColor="#0D47A1" TextColor="White" HeightRequest="50" CornerRadius="12" FontAttributes="Bold" ImageSource="calendar_icon.png" />
                    
                    <Button Text="Manage Clinic Schedule" 
                            Clicked="OnViewAllAppointmentsClicked"
                            BackgroundColor="White" TextColor="#0D47A1" HeightRequest="50" CornerRadius="12" FontAttributes="Bold" BorderColor="#0D47A1" BorderWidth="2" ImageSource="message_icon.png" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="DoctorView" Spacing="20" IsVisible="False">
                    <Border BackgroundColor="White" Stroke="#E0E6ED" StrokeThickness="1" Padding="20">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" /></Border.Shadow>
                        
                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                <BoxView Color="#27AE60" WidthRequest="10" HeightRequest="10" CornerRadius="5" VerticalOptions="Center" />
                                <Label Text="NEXT PATIENT WAITING" FontSize="12" FontAttributes="Bold" TextColor="#7F8C8D" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <Label x:Name="DoctorNextPatientTimeLabel" FontSize="22" FontAttributes="Bold" TextColor="#0D47A1" />
                            <Label x:Name="DoctorNextPatientDetailsLabel" FontSize="15" TextColor="#34495E" />
                            
                            <HorizontalStackLayout Spacing="10" Margin="0,15,0,0">
                                <Button Text="Write Diagnosis" BackgroundColor="#0D47A1" TextColor="White" CornerRadius="8" HeightRequest="40" FontAttributes="Bold" WidthRequest="150" />
                                
                                <Button x:Name="DoctorMorePatientsButton" 
                                        Clicked="OnDoctorSeeMoreClicked"
                                        BackgroundColor="#E3F2FD" 
                                        TextColor="#0D47A1" 
                                        BorderWidth="0" 
                                        CornerRadius="8" 
                                        HeightRequest="40" 
                                        FontAttributes="Bold" 
                                        Padding="15,0" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="My Tools" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" Margin="0,10,0,0"/>
                    
                    <Grid ColumnDefinitions="*, *" RowSpacing="15" ColumnSpacing="15">
                        <Border Grid.Column="0" BackgroundColor="White" StrokeThickness="0" HeightRequest="80">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" /></Border.Shadow>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnMyScheduleTapped"/></Border.GestureRecognizers>
                            
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="5">
                                <Image Source="calendar_icon.png" WidthRequest="24" HeightRequest="24" />
                                <Label Text="My Schedule" FontSize="12" FontAttributes="Bold" TextColor="#1C1C1E" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="White" StrokeThickness="0" HeightRequest="80">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" /></Border.Shadow>
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSetAvailabilityTapped"/></Border.GestureRecognizers>
                            
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="5">
                                <Image Source="settings_icon.png" WidthRequest="24" HeightRequest="24" />
                                <Label Text="Set Availability" FontSize="12" FontAttributes="Bold" TextColor="#1C1C1E" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>