<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.DashboardPage"
             BackgroundColor="#F5F5F7"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <view:HeaderBanner x:Name="PageBanner" Grid.Row="0" />

        <ScrollView Grid.Row="1" Margin="20,10,20,0">
            <VerticalStackLayout Spacing="20" Padding="0,0,0,30">
                
                <VerticalStackLayout x:Name="PatientDashboardContainer" IsVisible="False" Spacing="20">
                    
                    <Label Text="Your Next Appointment" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" />
                    
                    <Border Padding="20" BackgroundColor="White" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" /></Border.Shadow>
                        <VerticalStackLayout Spacing="5">
                            <Label x:Name="PatientNextApptLabel" Text="Tomorrow at 10:00 AM" FontSize="16" FontAttributes="Bold" TextColor="#0D47A1" />
                            <Label Text="Cardiology Department" FontSize="14" TextColor="#8E8E93" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="At a Glance" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" Margin="0,10,0,0" />
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        
                        <Border Grid.Column="0" Padding="15" BackgroundColor="White" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" /></Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                                <Label x:Name="UnreadMessagesLabel" Text="2" FontSize="24" FontAttributes="Bold" TextColor="#E74C3C" HorizontalOptions="Center" />
                                <Label Text="Unread Messages" FontSize="12" TextColor="#8E8E93" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <Border Grid.Column="1" Padding="15" BackgroundColor="White" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" /></Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                                <Label Text="1" FontSize="24" FontAttributes="Bold" TextColor="#27AE60" HorizontalOptions="Center" />
                                <Label Text="Active Prescription" FontSize="12" TextColor="#8E8E93" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Button Text="Book New Appointment" BackgroundColor="#0D47A1" TextColor="White" HeightRequest="55" CornerRadius="12" FontAttributes="Bold" Margin="0,20,0,0" Clicked="OnBookAppointmentClicked" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="DoctorDashboardContainer" IsVisible="False" Spacing="20">
                    
                    <Label Text="Today's Overview" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" />
                    
                    <Border Padding="20" BackgroundColor="#E3F2FD" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Label x:Name="DoctorStatsLabel" Text="You have 6 appointments today." FontSize="16" FontAttributes="Bold" TextColor="#0D47A1" HorizontalOptions="Center"/>
                    </Border>

                    <Label Text="Next Patient" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" Margin="0,10,0,0" />
                    
                    <Border Padding="20" BackgroundColor="White" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" /></Border.Shadow>
                        <VerticalStackLayout Spacing="5">
                            <Label x:Name="DoctorNextPatientLabel" Text="10:00 AM - John Doe" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" />
                            <Label Text="Reason: Routine Checkup" FontSize="14" TextColor="#8E8E93" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>