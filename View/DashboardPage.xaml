<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_app.View.DashboardPage"
             BackgroundColor="#F5F5F7"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        
        <Border Grid.Row="0" StrokeThickness="0" Margin="0" Padding="20,40,20,30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#42A5F5" Offset="0.1" />
                    <GradientStop Color="#0D47A1" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24" />
            </Border.StrokeShape>
            
            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                <Image Source="medical_logo.png" HeightRequest="50" WidthRequest="50" />
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Patient Dashboard" TextColor="#BBDEFB" FontSize="14" FontAttributes="Bold"/>
                    <Label x:Name="WelcomeLabel" Text="Welcome!" TextColor="White" FontSize="24" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" Margin="20,20,20,0">
            <VerticalStackLayout Spacing="20">
                
                <Label Text="Upcoming Appointment" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" />
                
                <Border Padding="20" BackgroundColor="White" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" />
                    </Border.Shadow>
                    
                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                        <Label Grid.Row="0" Grid.Column="0" Text="Dr. Sarah Jenkins" FontSize="18" FontAttributes="Bold" TextColor="#0D47A1" />
                        <Label Grid.Row="0" Grid.Column="1" Text="Cardiology" FontSize="14" TextColor="#42A5F5" FontAttributes="Bold" HorizontalOptions="End" />
                        
                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="Tomorrow at 10:00 AM" FontSize="16" TextColor="#1C1C1E" Margin="0,10,0,0" />
                        <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="Room 302, Main Building" FontSize="14" TextColor="#8E8E93" Margin="0,5,0,0" />
                    </Grid>
                </Border>

                <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E" Margin="0,10,0,0" />
                
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <Border Grid.Column="0" Padding="15" BackgroundColor="White" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" /></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                            <Label Text="💊" FontSize="32" HorizontalOptions="Center" />
                            <Label Text="Prescriptions" FontSize="14" FontAttributes="Bold" TextColor="#1C1C1E" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <Border Grid.Column="1" Padding="15" BackgroundColor="White" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.05" /></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                            <Label Text="🔬" FontSize="32" HorizontalOptions="Center" />
                            <Label Text="Test Results" FontSize="14" FontAttributes="Bold" TextColor="#1C1C1E" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Button Text="Book New Appointment" 
                        BackgroundColor="#0D47A1"
                        TextColor="White"
                        HeightRequest="55"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        Margin="0,20,0,10" />
                        
                <Button Text="Sign Out" 
                        Clicked="OnSignOutClicked"
                        BackgroundColor="Transparent"
                        TextColor="#FF3B30"
                        HeightRequest="50"
                        FontAttributes="Bold"
                        Margin="0,0,0,40" />
                        
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>