<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:view="clr-namespace:MAUI_app.View"
             x:Class="MAUI_app.View.AppointmentsPage"
             BackgroundColor="#F4F6F8"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <view:HeaderBanner x:Name="PageBanner" Grid.Row="0" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,10,20,30" Spacing="20">

                <VerticalStackLayout x:Name="PatientViewContainer" IsVisible="False" Spacing="20">

                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="My Appointments" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="+ Book New" BackgroundColor="#27AE60" TextColor="White" CornerRadius="20" HeightRequest="40" Padding="15,0" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView x:Name="PatientAppointmentsList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,15" BackgroundColor="White" Stroke="#E0E6ED" StrokeThickness="1" Padding="20">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.05" />
                                    </Border.Shadow>

                                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                                        
                                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                            <Label Text="{Binding DoctorName}" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Image Source="calendar_icon.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center">
                                                    <Image.Behaviors>
                                                        <toolkit:IconTintColorBehavior TintColor="#7F8C8D" />
                                                    </Image.Behaviors>
                                                </Image>
                                                <Label Text="{Binding AppointmentDate, StringFormat='{0:dd MMM yyyy - HH:mm}'}" TextColor="#7F8C8D" FontSize="14" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#E8F8F5" StrokeThickness="0" Padding="10,5" HorizontalOptions="End" VerticalOptions="Start">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Status}" TextColor="#27AE60" FontSize="12" FontAttributes="Bold" />
                                        </Border>

                                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="#F0F3F4" Margin="0,15,0,10" />

                                        <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" HorizontalOptions="End" Spacing="10">
                                            <Button Text="Cancel Appointment" BackgroundColor="Transparent" TextColor="#E74C3C" FontSize="14" FontAttributes="Bold" HeightRequest="35" Padding="10,0"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

                <VerticalStackLayout x:Name="DoctorViewContainer" IsVisible="False" Spacing="20">
                    
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Today's Schedule" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="Set Availability" BackgroundColor="#2980B9" TextColor="White" CornerRadius="20" HeightRequest="40" Padding="15,0" FontAttributes="Bold" />
                    </Grid>

                    <CollectionView x:Name="DoctorScheduleList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,15" BackgroundColor="White" Stroke="#E0E6ED" StrokeThickness="1" Padding="20">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.05" />
                                    </Border.Shadow>

                                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                                        
                                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                            <Label Text="{Binding PatientName}" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Image Source="calendar_icon.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center">
                                                    <Image.Behaviors>
                                                        <toolkit:IconTintColorBehavior TintColor="#7F8C8D" />
                                                    </Image.Behaviors>
                                                </Image>
                                                <Label Text="{Binding AppointmentDate, StringFormat='{0:HH:mm}'}" TextColor="#7F8C8D" FontSize="14" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#EBF5FB" StrokeThickness="0" Padding="10,5" HorizontalOptions="End" VerticalOptions="Start">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Status}" TextColor="#2980B9" FontSize="12" FontAttributes="Bold" />
                                        </Border>

                                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="#F0F3F4" Margin="0,15,0,10" />

                                        <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" HorizontalOptions="End" Spacing="10">
                                            <Button Text="Add Note" BackgroundColor="#F4F6F8" TextColor="#2C3E50" FontSize="14" FontAttributes="Bold" HeightRequest="35" Padding="15,0" CornerRadius="8"/>
                                            <Button Text="Cancel" BackgroundColor="#FDEDEC" TextColor="#E74C3C" FontSize="14" FontAttributes="Bold" HeightRequest="35" Padding="15,0" CornerRadius="8"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>